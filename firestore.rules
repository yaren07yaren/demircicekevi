rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection: publicly visible; writes allowed for admin operations
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
